      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "System Used",
          "description": "Total time with at least one EuroScope connection during the selected time range.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-prom"
                      },
                      "spec": {
                        "expr": "sum_over_time(((sum(websocket_connections_active{deployment_environment=\"$env\",source=\"euroscope\",airport=\"$airport\",session_name=\"$session\"}) > bool 0))[$__range:1m]) / 60",
                        "legendFormat": "Used"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
