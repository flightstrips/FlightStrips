{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "At-a-glance health view — error counts, live error stream, and recent trends",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "external link",
      "tags": ["flightstrips"],
      "title": "Backend Overview",
      "tooltip": "Open the full backend metrics dashboard",
      "type": "dashboards",
      "url": "/d/flightstrips-backend"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Current Status — last $__range",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [{"options": {"0": {"color": "green", "index": 0, "text": "None"}}, "type": "value"}],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"flightstrips-backend\", level=\"ERROR\"}[$__range]))",
          "instant": true,
          "range": false,
          "legendFormat": "Errors"
        }
      ],
      "title": "Error Logs",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [{"options": {"0": {"color": "green", "index": 0, "text": "None"}}, "type": "value"}],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 10}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"flightstrips-backend\", level=\"WARN\"}[$__range]))",
          "instant": true,
          "range": false,
          "legendFormat": "Warnings"
        }
      ],
      "title": "Warning Logs",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [{"options": {"0": {"color": "green", "index": 0, "text": "None"}}, "type": "value"}],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(websocket_message_duration_seconds_count{status=\"error\"}[$__range])) or vector(0)",
          "legendFormat": "Handler Errors"
        }
      ],
      "title": "Handler Failures",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(websocket_message_duration_seconds_count{status=\"error\"}[5m])) / sum(rate(websocket_message_duration_seconds_count[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "title": "Error Rate (5m avg)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [{"options": {"0": {"color": "red", "index": 0, "text": "Offline"}}, "type": "value"}],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 16, "y": 1},
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(websocket_connections_active) or vector(0)",
          "legendFormat": "Connections"
        }
      ],
      "title": "Active Connections",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.5}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 20, "y": 1},
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "text": {"titleSize": 16, "valueSize": 48}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(websocket_message_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 Latency"
        }
      ],
      "title": "P99 Latency",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 8,
      "title": "Error Trends",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "WARN"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 9,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"flightstrips-backend\", level=\"ERROR\"}[$__interval]))",
          "instant": false,
          "range": true,
          "legendFormat": "ERROR"
        },
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"flightstrips-backend\", level=\"WARN\"}[$__interval]))",
          "instant": false,
          "range": true,
          "legendFormat": "WARN"
        }
      ],
      "title": "Log Errors & Warnings Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"},
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "error"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 10,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(websocket_message_duration_seconds_count{status=\"error\"}[2m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "title": "Handler Failures by Message Type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 11,
      "title": "Error Log Stream",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 17},
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"flightstrips-backend\", level=~\"ERROR|WARN\"}",
          "legendFormat": ""
        }
      ],
      "title": "Errors & Warnings (click any log line → View Trace)",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["flightstrips"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "FlightStrips – Ops Health",
  "uid": "flightstrips-ops-health",
  "version": 1,
  "weekStart": ""
}
